<Project>

  <Target Name="Coveraging">
    <Exec Command='dotnet test \
      -p:CollectCoverage=true \
      -p:CoverletOutputFormat="lcov" \
      -p:CoverletOutput="./lcov.info" \
      -p:Include="[%2A]$(MSBuildProjectName).%2A" \
      -p:Exclude="[%2A]%2A.AutoGeneratedProgram" \
      -p:Exclude="[%2A]%2A.Test%2A" \
      -p:IncludeTestAssembly=true \
      -p:Threshold=80 \
      --no-restore --no-build --nologo'
    />
  </Target>

  <Target Name="Testing">
    <Exec Command='dotnet test \
      -p:BuildProjectReferences=false \
      --no-restore --nologo'
    />
  </Target>

  <Target Name="Packing">
    <Exec Command='dotnet pack \
      -p:BuildProjectReferences=false \
      -c Release \
      -o "$(MSBuildProjectDirectory)"/../.packages \
      --no-restore --nologo'
    />
  </Target>

</Project>
